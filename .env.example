# JWT settings
JWT_SECRET=your_jwt_secret_key_here
JWT_ALG=HS256
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=14

# CORS allowlist (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081

# Endpoint manual de varredura
# Em produção, mantenha como false
ENABLE_MANUAL_MONITOR_ENDPOINT=false

# Login lockout
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_LOCKOUT_MAX_MINUTES=60

# Rate limits per minute
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_REFRESH_PER_MIN=20
RATE_LIMIT_API_PER_MIN=120

# Banco de dados (deixe vazio para usar o padrão local)
# DATABASE_PATH=/app/data/prismacare.db

# Frontend — URL base da API (prefixo EXPO_PUBLIC_ é obrigatório)
# Desenvolvimento: http://localhost:8000 ou http://10.0.2.2:8000 (Android)
# Produção: https://seudominio.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
